# 复制为 .env 后填入（.env 已在 .gitignore，不会提交）

# 后端 API 地址（真机 Expo Go 必须用电脑局域网 IP，不能用 localhost）
# EXPO_PUBLIC_API_BASE_URL=http://172.30.60.49:3000

# 高德「Web端(JS API)」—— TripMap WebView 地图专用（与后端 AMAP_WEB_KEY 是不同 Key）
# 控制台：https://console.amap.com/dev/key/app
# 服务平台选「Web端(JS API)」，域名白名单留空，提交后拿到 Key + securityJsCode
EXPO_PUBLIC_AMAP_JS_KEY=
EXPO_PUBLIC_AMAP_JS_SECURITY=
