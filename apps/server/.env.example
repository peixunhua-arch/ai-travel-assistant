# 复制此文件为 .env 并填入真实值（.env 不会提交到 git）

# ===== 聊天：豆包（火山方舟 OpenAI 兼容）=====
# 控制台：https://console.volcengine.com/ark
# DOUBAO_MODEL 一般是「推理接入点」ID，形如 ep-xxxxxxxxxxxxxxxx
DOUBAO_API_KEY=your-ark-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-xxxxxxxxxxxxxxxx

# ===== 行程：DeepSeek（OpenAI 兼容 + Tool Calling）=====
# 文档：https://api-docs.deepseek.com
# 若账号暂无 deepseek-v4，可改为 deepseek-chat 或 deepseek-reasoner
DEEPSEEK_API_KEY=sk-xxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4

# 签发 JWT 用的随机长字符串（自己乱敲一串即可）
JWT_SECRET=change-me-to-a-long-random-string

# 服务端口
PORT=3000

# ---- 地图 / 天气（行程 Agent 工具依赖）----
# AMAP_WEB_KEY=
# QWEATHER_KEY=
# QWEATHER_API_HOST=xxx.qweatherapi.com
# QWEATHER_GEO_HOST=geoapi.qweather.com

# ---- 可选：限流（每分钟，默认 chat=20 / trip=5）----
# RATE_LIMIT_CHAT_PER_MIN=20
# RATE_LIMIT_TRIP_PER_MIN=5

# ---- 可选：保留 Claude（旧实现仍在 services/claude.ts，默认路由已不用）----
# CLAUDE_BASE_URL=https://aigateway-test.iboxchain.com/v2
# CLAUDE_AUTH_TOKEN=sk-huapeixun-xxxxx
# CLAUDE_MODEL=claude-sonnet-4-6
