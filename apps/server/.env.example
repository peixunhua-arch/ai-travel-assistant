# 复制此文件为 .env 并填入真实值（.env 不会提交到 git）

# ===== Claude 接入：走网关 或 直连官方，二选一 =====

# 方式 A（当前推荐，国内可用）：课程网关 + Bearer 令牌
CLAUDE_BASE_URL=https://aigateway-test.iboxchain.com/v2
CLAUDE_AUTH_TOKEN=sk-huapeixun-xxxxx
# 网关目前只支持 Opus/Sonnet 4.x，没有 Haiku
CLAUDE_MODEL=claude-sonnet-4-6

# 方式 B（有代理/VPN 时）：自己的官方 Key 直连 api.anthropic.com
# 用方式 B 时：把上面 CLAUDE_BASE_URL / CLAUDE_AUTH_TOKEN 注释掉，填下面这个
# CLAUDE_API_KEY=sk-ant-xxxxx

# 签发 JWT 用的随机长字符串（自己乱敲一串即可）
JWT_SECRET=change-me-to-a-long-random-string

# 服务端口
PORT=3000

# ---- 以下阶段 3 才需要，阶段 1 可留空 ----
# AMAP_WEB_KEY=
# QWEATHER_KEY=
# QWEATHER_API_HOST=xxx.qweatherapi.com
# QWEATHER_GEO_HOST=geoapi.qweather.com
# DATABASE_URL=

# ---- 可选：限流（每分钟，默认 chat=20 / trip=5）----
# RATE_LIMIT_CHAT_PER_MIN=20
# RATE_LIMIT_TRIP_PER_MIN=5
